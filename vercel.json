{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/custody-alerts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/notify-email",
      "schedule": "10 3 * * *"
    },
    {
      "path": "/api/cron/zoho-sync",
      "schedule": "20 3 * * *"
    }
  ]
}