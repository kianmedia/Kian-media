# ── Supabase — Client Portal (بوابة العملاء) ────────────────────────────
# Get both values from: Supabase Dashboard → Project Settings → API
#
# Local development: copy this file to .env.local and fill in the values.
# Production (Vercel): add the same two variables under
#   Project → Settings → Environment Variables, then redeploy.
#
# Note: the URL is the project base URL only — do NOT append /rest/v1 or /auth/v1.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── WhatsApp Inbox ingest (SERVER-ONLY — never NEXT_PUBLIC) ──────────────
# Shared secret n8n must send in the `x-kian-ingest-secret` header.
# Generate a long random value (e.g. `openssl rand -hex 32`).
N8N_WHATSAPP_INGEST_SECRET=

# Supabase service-role key — used ONLY by the server ingest route to call the
# whatsapp_ingest_message RPC. NEVER expose to the browser. From Supabase
# Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: server-side project URL. Falls back to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=

# ── WhatsApp outbound send (SERVER-ONLY — reply from portal) ─────────────
# DRY-RUN by default: replies are recorded in the conversation but NOT sent
# until WHATSAPP_SEND_ENABLED=true AND the token+phone id are set. Do NOT enable
# on the LIVE number until the flow is reviewed (Checkpoint ب).
WHATSAPP_SEND_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
# Comma-separated phone numbers allowed to receive REAL sends while testing.
# When set AND WHATSAPP_SEND_ENABLED=true, any number NOT in this list is BLOCKED
# (recorded, not sent). Leave empty for no extra gate (production-wide send).
WHATSAPP_SEND_TEST_ALLOWLIST=

# ── AI Agent (gated — SERVER-ONLY; NOT attached to live customers) ──────
# All OFF/draft by default. AI never auto-replies to live numbers. When enabled,
# it only drafts suggestions (AI_DRAFT_ONLY=true) and is limited to AI_TEST_ALLOWLIST.
AI_AGENT_ENABLED=false
AI_DRAFT_ONLY=true
AI_PROVIDER=claude
AI_API_KEY=
AI_TEST_ALLOWLIST=

# ── WhatsApp email alerts (SERVER-ONLY; department-scoped) ───────────────
# DISABLED by default. When 'true', a new WhatsApp message emails owner/admin/
# manager + the relevant department only. Reuses the existing Apps Script channel
# (no SMTP keys here) — the Apps Script must handle Event "whatsapp_new". Email
# failure never blocks ingest.
WHATSAPP_EMAIL_ALERTS_ENABLED=false
# Optional override for the notify endpoint (defaults to the Apps Script URL).
PORTAL_NOTIFY_ENDPOINT=
# Optional public base for links in emails (defaults to https://www.kianmedia.com).
PORTAL_PUBLIC_URL=

# ── Internal staff WhatsApp alerts (gated — keep OFF) ───────────────────
# Schema/settings exist (whatsapp_staff_alert_settings). NO real staff WhatsApp
# alerts are sent unless enabled AND the staff alert phone is allow-listed.
WHATSAPP_STAFF_ALERTS_ENABLED=false
WHATSAPP_INTERNAL_ALERTS_ENABLED=false
WHATSAPP_INTERNAL_ALERTS_TEST_ALLOWLIST=

# ── Start-new-conversation / WhatsApp templates (gated — keep OFF) ───────
# Starting a chat with a new number requires an approved Meta template. All OFF
# by default; template sends restricted to the allowlist when enabled.
WHATSAPP_START_CONVERSATION_ENABLED=false
WHATSAPP_TEMPLATE_SEND_ENABLED=false
WHATSAPP_TEMPLATE_TEST_ALLOWLIST=

# ── Auto quote-link reply on price intent (rule-based, gated — keep OFF) ──
# When an inbound message asks about price/quote/cost, optionally auto-reply with a
# quote-request link. OFF by default; dry-run logs an internal note without sending;
# allowlist restricts real sends; cooldown avoids spamming the same conversation.
WHATSAPP_AUTO_QUOTE_LINK_ENABLED=false
WHATSAPP_AUTO_QUOTE_LINK_DRY_RUN=true
WHATSAPP_AUTO_QUOTE_LINK_TEST_ALLOWLIST=
WHATSAPP_AUTO_QUOTE_LINK_COOLDOWN_HOURS=6

# ── Customer confirmation after a WhatsApp quote submission (gated — keep OFF) ─
# Email goes through the Apps Script channel (Event "quote_received"); WhatsApp is a
# free-form session message restricted to the allowlist. Both non-blocking + OFF.
QUOTE_REQUEST_CUSTOMER_EMAIL_ENABLED=false
QUOTE_REQUEST_CUSTOMER_WHATSAPP_CONFIRM_ENABLED=false
QUOTE_REQUEST_CUSTOMER_WHATSAPP_CONFIRM_TEST_ALLOWLIST=

# ── WhatsApp inbox client-side debug logging (safe; no secrets) ──────────
# Logs (browser console) the selected conversation id + quote-request count +
# any query error. Auto-on in local dev; set to 1 to also see it on Vercel
# Preview (NODE_ENV is "production" there). Leave blank in Production.
NEXT_PUBLIC_WA_DEBUG=

# ── Zoho CRM — Saudi Arabia (.sa) data center (SERVER-ONLY) ──────────────
# When unset, WhatsApp→Zoho lead sync is a safe no-op (ingest still succeeds).
# IMPORTANT: client id/secret + refresh token must be minted on the .sa DC
# (accounts.zoho.sa). A US-DC secret yields invalid_client; a US token used on
# the .sa API yields INVALID_TOKEN. Note hosts: accounts = no "www", api = "www".
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.sa
# Fallback base; at runtime the token response's api_domain (https://www.zohoapis.sa) is preferred.
ZOHO_CRM_API_BASE=https://www.zohoapis.sa/crm/v5

# ── Zoho Books — DRAFT estimates only (SERVER-ONLY, gated — keep OFF) ────────
# Creates a DRAFT عرض سعر / تقدير only. NEVER sends estimates, NEVER creates
# invoices, NEVER issues ZATCA e-invoices. Reuses the shared ZOHO_* OAuth app
# (the refresh token's scope must include ZohoBooks.estimates.CREATE +
# ZohoBooks.contacts.*). Off by default; draft-only guard defaults true.
ZOHO_BOOKS_ESTIMATES_ENABLED=false
ZOHO_BOOKS_ESTIMATE_DRAFT_ONLY=true
ZOHO_BOOKS_ORGANIZATION_ID=
# Optional overrides (defaults shown). VAT tax id is only applied if set.
ZOHO_BOOKS_API_BASE=https://www.zohoapis.sa/books/v3
ZOHO_BOOKS_VAT_TAX_ID=

# ── Zoho Books — READ-ONLY invoice sync into the portal (SERVER-ONLY) ────────
# The /api/integrations/zoho/sync-invoices route READS a customer's invoices
# (matched by email) and mirrors them as read-only portal records. It NEVER
# creates/sends/edits/voids anything in Zoho. Missing vars → graceful setup
# message (no failure). These spec-named vars are read first, falling back to the
# ZOHO_BOOKS_* / ZOHO_ACCOUNTS_URL names above when unset.
ZOHO_ORGANIZATION_ID=
ZOHO_API_BASE_URL=https://www.zohoapis.sa/books/v3
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.sa
# OAuth scopes the refresh token needs for the ESTIMATES integration (quotes source
# of truth) — invoices need only READ:
#   ZohoBooks.contacts.READ, ZohoBooks.contacts.CREATE,
#   ZohoBooks.estimates.READ, ZohoBooks.estimates.CREATE, ZohoBooks.estimates.UPDATE,
#   ZohoBooks.invoices.READ
# Tax-invoice approval flow (create the official invoice from an accepted estimate)
# ALSO needs — but ONLY for that flow; estimate-only flows do not require it:
#   ZohoBooks.invoices.CREATE

# ── Notification Delivery Layer (STAGE 1: logging/observability only) ─────────
# Stage 1 only writes delivery rows (portal=sent, email/whatsapp=pending/skipped) so
# routing can be verified BEFORE any real send. These flags gate the Stage-2 processor
# and external senders; ALL default OFF. No email/WhatsApp is sent while these are off.
DELIVERY_PROCESSOR_ENABLED=false   # master switch for the (future) delivery processor route/cron
EMAIL_SEND_ENABLED=false           # actually send email (else dry-run/skip)
WHATSAPP_DELIVERY_ENABLED=false    # actually send WhatsApp (else dry-run/skip; needs approved templates)
DELIVERY_DRY_RUN=true              # when the processor runs, mark rows dry_run instead of sending
# Comma-separated allowlists for safe Stage-2 testing (only these destinations get real sends):
EMAIL_TEST_ALLOWLIST=
WHATSAPP_TEST_ALLOWLIST=
